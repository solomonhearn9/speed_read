# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY_ID=price_...
STRIPE_PRICE_LIFETIME_ID=price_...
# Enable Customer Portal in Stripe Dashboard → Settings → Billing → Customer portal

# App URL (used for auth email redirects, Stripe billing portal, etc.)
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev-only plan indicator in production builds (default: hidden)
# NEXT_PUBLIC_SHOW_PLAN_INDICATOR=true

# PostHog (https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Microsoft Clarity (https://clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Supabase setup checklist:
# 1. Authentication → URL Configuration → add redirect URL:
#    {NEXT_PUBLIC_APP_URL}/api/auth/callback
# 2. For email links opened outside the signup browser, update the
#    "Confirm signup" email template link to:
#    {{ .RedirectTo }}?token_hash={{ .TokenHash }}&type=signup
